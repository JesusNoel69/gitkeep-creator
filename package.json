{
  "name": "gitkeep-creator",
  "displayName": ".gitkeep creator",
  "description": "A project to allow adding .gitkeep files in empty folders",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitkeep-creator.managefiles",
        "title": "Files .gitkeep"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitkeep-creator",
          "title": ".gitkeep files creator",
          "icon": "resources/gitkeep.svg"
        }
      ]
    },
    "views": {
      "gitkeep-creator": [
        {
          "type": "webview",
          "id": "gitkeepPanel",
          "name": "Gitkeep Panel",
          "icon": "resources/gitkeep.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
